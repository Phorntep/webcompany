                                        <a href="#"  >WEBBOARD</a>
                                        <a href="#about">JOB</a>
                                        <a href="#about">ABOUT</a>
                                         <a href="javascript:void(0);" style="font-size:15px;" class="icon" onclick="myFunction()">&#9776;</a>
                                    </div>
                                </div>

                            </div>
                            <asp:ContentPlaceHolder ID="ContentPlaceHolder1" runat="server">
                                sdasdsad
